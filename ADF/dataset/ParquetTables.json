{
    "name": "ParquetTables",
    "properties": {
        "linkedServiceName": {
            "referenceName": "AzureDataLakeStorage_ls",
            "type": "LinkedServiceReference"
        },
        "parameters": {
            "shemaname": {
                "type": "string"
            },
            "tablename": {
                "type": "string"
            }
        },
        "annotations": [],
        "type": "Parquet",
        "typeProperties": {
            "location": {
                "type": "AzureBlobFSLocation",
                "fileName": {
                    "value": "@{concat(dataset().tablename,'.parquet')}",
                    "type": "Expression"
                },
                "folderPath": {
                    "value": "@{concat(dataset().shemaname,'/',dataset().tablename)}",
                    "type": "Expression"
                },
                "fileSystem": "bronze"
            },
            "compressionCodec": "snappy"
        },
        "schema": []
    },
    "type": "Microsoft.DataFactory/factories/datasets"
}